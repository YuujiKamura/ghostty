{
  "name": "winui3-host-contract",
  "required_artifact_filenames": [
    "Microsoft.WindowsAppRuntime.Bootstrap.dll",
    "ghostty.manifest"
  ],
  "required_reference_filenames": [
    "App.winmd",
    "MainWindow.winmd",
    "XamlMetaDataProvider.winmd",
    "WinUI3Ref.winmd"
  ],
  "source_must_contain": [
    {
      "file": "src/apprt/winui3/delegate_runtime.zig",
      "pattern": "delegate_iid"
    },
    {
      "file": "src/apprt/winui3/App.zig",
      "pattern": "createWithIid"
    },
    {
      "file": "src/apprt/winui3/com.zig",
      "pattern": "IID_TypedEventHandler_TabCloseRequested"
    },
    {
      "file": "src/apprt/winui3/com.zig",
      "pattern": "IID_TypedEventHandler_AddTabButtonClick"
    },
    {
      "file": "src/apprt/winui3/com.zig",
      "pattern": "IID_SelectionChangedEventHandler"
    },
    {
      "file": "src/apprt/winui3/com.zig",
      "pattern": "IID_SizeChangedEventHandler"
    },
    {
      "file": "src/apprt/winui3/com.zig",
      "pattern": "pub const IPanel = gen.IPanel;"
    },
    {
      "file": "src/apprt/winui3/com.zig",
      "pattern": "pub const IApplicationFactory = gen.IApplicationFactory;"
    },
    {
      "file": "src/apprt/winui3/com_runtime.zig",
      "pattern": "IApplicationFactory.createInstance returns structured result"
    },
    {
      "file": "src/apprt/winui3/com_runtime.zig",
      "pattern": "ITabView surface methods required by App are present"
    },
    {
      "file": "src/apprt/winui3/com_runtime.zig",
      "pattern": "delegate/event IID constants required by runtime are present"
    }
  ],
  "line_order_checks": [
    {
      "file": "src/apprt/winui3/App.zig",
      "first_pattern": "Step 8: Create initial Surface and content.",
      "second_pattern": "try self.registerTabViewHandlers(tab_view);",
      "expectation": "first_before_second",
      "description": "Control tree creation should be completed before handler registration."
    }
  ]
}
